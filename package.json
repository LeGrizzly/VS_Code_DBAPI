{
  "name": "SILODB-explorer",
  "displayName": "SILODB Explorer",
  "description": "Browse and edit FS25 SILODB database files directly from VS Code",
  "version": "2.0.2",
  "publisher": "LeGrizzly",
  "repository": {
    "type": "git",
    "url": "https://github.com/LeGrizzly/VS_Code_SILODB/tree/main"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:lua"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "SILODB-explorer",
          "title": "SILODB Explorer",
          "icon": "resources/database.svg"
        }
      ]
    },
    "views": {
      "SILODB-explorer": [
        {
          "id": "SILODBDatabaseView",
          "name": "Database"
        }
      ]
    },
    "commands": [
      {
        "command": "SILODB.setDataPath",
        "title": "SILODB: Set Database Path",
        "icon": "$(folder-opened)"
      },
      {
        "command": "SILODB.autoDetect",
        "title": "SILODB: Auto-Detect Savegames",
        "icon": "$(search)"
      },
      {
        "command": "SILODB.refresh",
        "title": "SILODB: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "SILODB.addEntry",
        "title": "Add Entry",
        "icon": "$(add)"
      },
      {
        "command": "SILODB.editEntry",
        "title": "Edit Value",
        "icon": "$(edit)"
      },
      {
        "command": "SILODB.deleteEntry",
        "title": "Delete Entry",
        "icon": "$(trash)"
      },
      {
        "command": "SILODB.addNamespace",
        "title": "SILODB: Add Namespace",
        "icon": "$(new-folder)"
      },
      {
        "command": "SILODB.deleteNamespace",
        "title": "Delete Namespace",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "SILODB.autoDetect",
          "when": "view == SILODBDatabaseView",
          "group": "navigation@1"
        },
        {
          "command": "SILODB.setDataPath",
          "when": "view == SILODBDatabaseView",
          "group": "navigation@2"
        },
        {
          "command": "SILODB.refresh",
          "when": "view == SILODBDatabaseView",
          "group": "navigation@3"
        },
        {
          "command": "SILODB.addNamespace",
          "when": "view == SILODBDatabaseView",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "SILODB.addEntry",
          "when": "view == SILODBDatabaseView && viewItem == namespace",
          "group": "inline@1"
        },
        {
          "command": "SILODB.addEntry",
          "when": "view == SILODBDatabaseView && viewItem == object",
          "group": "inline@1"
        },
        {
          "command": "SILODB.editEntry",
          "when": "view == SILODBDatabaseView && viewItem == object",
          "group": "inline@2"
        },
        {
          "command": "SILODB.editEntry",
          "when": "view == SILODBDatabaseView && viewItem == leaf",
          "group": "inline@1"
        },
        {
          "command": "SILODB.deleteEntry",
          "when": "view == SILODBDatabaseView && viewItem == object",
          "group": "inline@3"
        },
        {
          "command": "SILODB.deleteEntry",
          "when": "view == SILODBDatabaseView && viewItem == leaf",
          "group": "inline@2"
        },
        {
          "command": "SILODB.deleteNamespace",
          "when": "view == SILODBDatabaseView && viewItem == namespace",
          "group": "inline@2"
        }
      ]
    },
    "snippets": [
      {
        "language": "lua",
        "path": "./snippets/SILODB.code-snippets"
      }
    ],
    "configuration": {
      "title": "SILODB Explorer",
      "properties": {
        "SILODB.dataPath": {
          "type": "string",
          "default": "",
          "description": "Path to the SILODB_data directory."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "package": "vsce package",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}
